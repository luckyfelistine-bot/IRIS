# IRIS v7.0 Secure Configuration
# Copy this file to .env and fill in your actual API keys

# GROQ API Keys for Different Models
GROQ_API_KEY_PRIMARY=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
GROQ_API_KEY_SECONDARY=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

# Flask Configuration
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# Database
DATABASE_URL=sqlite:///iris_secure_v7.db

# Security
ENABLE_CSRF=True
SESSION_TIMEOUT_MINUTES=60
MAX_CONTENT_LENGTH=52428800

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=200 per hour

# Features
ENABLE_VOICE=True
ENABLE_DOCUMENTS=True
ENABLE_CHARTS=True
ENABLE_AUTOMATIONS=True

# File Upload
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=txt,md,pdf,doc,docx,py,js,html,css,json,csv,xls,xlsx,png,jpg,jpeg,gif

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/iris.log
