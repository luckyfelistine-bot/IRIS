# IRIS v7 — Aevibron Partner Configuration
# Paste these into Vercel Environment Variables

# === AEVIBRON AI GATEWAY ===
AEVIBRON_BASE_URL=https://aevibron-gateway.vercel.app/api/v1
AEVIBRON_API_KEY=your_aevibron_api_key_here
AEVIBRON_ACCESS_TOKEN=your_iris_access_token_here

# === GITHUB ===
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username

# === VERCEL ===
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=your_team_id_if_any

# === SECURITY ===
IRIS_PASSWORD_HASH=your_bcrypt_hash_of_AevibronnorbiveA
WEBAUTHN_RP_NAME=IRIS
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5000

# === DATABASE ===
DATABASE_URL=sqlite:///data/iris.db

# === VOICE ===
EDGE_TTS_VOICE=en-US-AriaNeural

# === APP ===
FLASK_SECRET_KEY=generate_a_random_secret_key
FLASK_ENV=production
DEBUG=False
